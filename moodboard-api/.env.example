# Database — asyncpg driver
# Supabase: Dashboard → Settings → Database → Connection string (URI)
# Note: postgresql:// is auto-converted to postgresql+asyncpg://
DATABASE_URL=postgresql://user:password@db.your-project-ref.supabase.co:5432/postgres

# Upstash Redis REST — console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Upstash QStash — console.upstash.com → QStash
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# Groq AI — console.groq.com (free tier, no card required)
GROQ_API_KEY=your-groq-api-key

# Supabase — Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret          # Settings → API → JWT Settings → JWT Secret
SUPABASE_SERVICE_KEY=your-service-role-key   # Settings → API → service_role — NEVER expose to browser

# Environment
ENVIRONMENT=development
# API_BASE_URL=http://localhost:8000         # set in production to your Vercel URL

# Instagram oEmbed (optional — falls back to OG scraping without this)
# INSTAGRAM_ACCESS_TOKEN=your-instagram-token
